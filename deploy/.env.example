# ── TrafficFlow environment variables ──────────────────────────────────────
# Copy to deploy/.env and fill in real values before running:
#   cp deploy/.env.example deploy/.env
#   docker compose -f deploy/docker-compose.yml up --build
# Never commit .env to version control.

APP_ENV=production
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# WARNING: Replace all CHANGE_ME values before deploying to production.
POSTGRES_USER=trafficflow
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=trafficflow
POSTGRES_PORT=5432
DATABASE_URL=postgresql://trafficflow:CHANGE_ME_IN_PRODUCTION@postgres:5432/trafficflow

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── API server ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
MAX_WORKERS=2
CORS_ORIGINS=http://localhost:3000
SERVE_FRONTEND=false

# ── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
# Browser-visible API base through nginx. Use http://localhost:8000 only when
# the frontend is exposed separately from the bundled reverse proxy.
API_BASE_URL=/

# ── Nginx (public-facing port) ───────────────────────────────────────────────
HTTP_PORT=80

# ── AI worker ───────────────────────────────────────────────────────────────
MODEL_FILE=yolo11n.pt         # filename inside ../weights/
DETECT_EVERY_N_FRAMES=2
HALF_PRECISION=false          # set true only when using --profile gpu

# ── Paths (inside containers, do not change) ────────────────────────────────
APP_CONFIG=/app/configs/app.yaml
MODELS_CONFIG=/app/configs/models.yaml
CAMERAS_DIR=/app/configs/cameras
OUTPUT_DIR=/app/outputs
STORAGE_ROOT=/app/storage
WEIGHTS_DIR=/app/weights
CONFIG_DIR=/app/configs
