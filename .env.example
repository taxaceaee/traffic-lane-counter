DATABASE_URL=sqlite:///./data/trafficflow.db
JWT_SECRET=trafficflow_local_dev_secret_change_me
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=

# YouTube live extraction (local development only; never commit cookie files)
# YOUTUBE_COOKIES_FROM_BROWSER=chrome:Default
# YOUTUBE_COOKIES_FILE=/secure/path/youtube-cookies.txt
YTDLP_REMOTE_COMPONENTS=ejs:github
YTDLP_POT_PROVIDER=true
YTDLP_BGUTIL_PORT=4416
CORS_ORIGINS=http://localhost:3000
MAX_WORKERS=1
WEIGHTS_DIR=weights
MODEL_FILE=yolo11n.pt
REDIS_HOST=localhost
REDIS_PORT=6379
HALF_PRECISION=false
STORAGE_ROOT=data/storage
OUTPUT_DIR=data/outputs
SERVE_FRONTEND=true
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000
API_BASE_URL=http://localhost:8000
# Start detection for every camera YAML at API boot (Dashboard/Events data
# without opening Live). Set false to keep on-demand MJPEG-only start.
AUTO_START_LIVE_STREAMS=true
LOG_LEVEL=INFO
LOG_FORMAT=text

# ── Realtime multi-cam budget (laptop / multi always-on) ───────────────────
# fps = multi-cam every-2 for headless, viewer every-1 (default)
# recall = every frame always (slower multi-cam)
LIVE_RECALL_MODE=fps
LIVE_MAX_IMGSZ=960
LIVE_PREVIEW_MAX_EDGE=960
ALWAYS_ON_DETECT_EVERY_N=2
LIVE_VIEWER_DETECT_EVERY_N=1
