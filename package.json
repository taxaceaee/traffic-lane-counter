{
  "name": "trafficflow",
  "version": "1.0.0",
  "private": true,
  "description": "TrafficFlow — Vision-based Vehicle Counting System",
  "scripts": {
    "dev": "python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000 --reload",
    "dashboard": "python -m streamlit run frontend/app.py --server.port 8501",
    "start": "python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000",
    "start:all": "concurrently --names api,dash --prefix-colors blue,green \"npm run start\" \"npm run dashboard\"",
    "lint": "ruff check .",
    "lint:fix": "ruff check --fix .",
    "seed": "python scripts/seed_db.py",
    "pipeline": "python run_occupancy.py",
    "clean": "find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null; find . -type f -name '*.pyc' -delete"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
